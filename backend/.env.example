APP_NAME="Danuzio History Backstage"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=danuzio_backstage
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@danuziohistory.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Resend API (preferencial ao SMTP)
RESEND_API_KEY=

# Lastlink
LASTLINK_WEBHOOK_SECRET=
LASTLINK_API_URL=https://lastlink.com/api/v1
LASTLINK_API_TOKEN=
LASTLINK_API_KEY=
LASTLINK_CACHE_TTL=600

# Storage S3 (opcional — usar local em dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sanctum SPA
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
